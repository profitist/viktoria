# База данных PostgreSQL
DATABASE_URL=postgresql+asyncpg://victory:victory@postgres:5432/victory

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# JWT (сгенерируй случайную строку для продакшена)
JWT_SECRET=change-me-generate-random-secret-here

# AI API (OpenAI-compatible endpoint)
AI_API_URL=https://api.openai.com/v1/
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o

# URL для обращения фронта к backend
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# CORS
CORS_ORIGINS=http://localhost:3000

# MinIO / S3 Storage
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=victory-attachments
ATTACHMENT_MAX_SIZE=10485760
ATTACHMENT_URL_TTL=3600

# Docker images (для продакшен-деплоя)
FRONTEND_IMAGE=ghcr.io/your-org/victory-frontend:latest
BACKEND_IMAGE=ghcr.io/your-org/victory-backend:latest
